<main id="top">

  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="hero wrap">
    <div class="hero__inner">
      <div class="hero__tag"><span class="pip"></span>Available for opportunities · 2026</div>

      <h1 class="hero__name">
        <span class="l1">Saurabh</span>
        <span class="l2">Pandey.</span>
      </h1>

      <div class="hero__role">
        <span>Electrical Engineer</span>
        <span class="sep">/</span>
        <span>Data Scientist</span>
        <span class="sep">/</span>
        <span>AI Builder</span>
      </div>

      <p class="hero__bio">
        I build at the intersection of <em>physics and machine learning</em> — systems where electrochemical models meet neural networks, where signal data becomes intelligence. Currently engineering a patented Battery Passport at Suavy Technologies and pursuing my B.Tech in EEE at BIT Mesra.
      </p>

      <div class="hero__cta">
        <a href="#projects" class="btn btn--primary">View Work <span class="arrow">→</span></a>
        <a href="Saurabh_Pandey_Resume_DataScience.pdf" download class="btn btn--ghost">Download Résumé <span class="arrow">↓</span></a>
      </div>
    </div>

    <div class="scroll-prompt">
      <span>Scroll</span>
      <span class="line"></span>
    </div>
  </section>

  <!-- ============================================================
       ABOUT — 01
       ============================================================ -->
  <section id="about" class="wrap">
    <div class="sec-head reveal">
      <span class="sec-head__num">01 — Profile</span>
      <h2 class="sec-head__title">About <em>me.</em></h2>
      <span class="sec-head__rule"></span>
    </div>

    <div class="about">
      <div class="about__main reveal delay-1">
        <p class="about__lede">
          An electrical engineering student whose center of gravity has shifted to <em>data science and AI</em> — comfortable in both circuit diagrams and Jupyter notebooks.
        </p>
        <div class="about__body">
          <p>
            I'm a final-year B.Tech (EEE) at <strong style="color:var(--text)">Birla Institute of Technology, Mesra</strong>, holding a CGPA of 8.32. My core engineering training in power systems, EVs and PCB design now sits underneath everything I build in data — and that combination is where I do my most interesting work.
          </p>
          <p>
            Most recently I worked on a <strong style="color:var(--text)">patent-filed Battery Passport</strong> at Suavy Technologies, where neural networks, Particle Swarm Optimization and electrochemical modeling come together to estimate State of Charge and State of Health on-device, without labels. Before that I shipped a production RAG chatbot and a multimodal AI health assistant using FastAPI, LangGraph, and GPT-4o.
          </p>
          <p>
            When I'm not writing code, I'm leading <strong style="color:var(--text)">Team Aveon Racing</strong> as Vice Captain (we placed 2nd runner-up at E-Baja SAEINDIA 2025) and presiding over BIT Mesra's <strong style="color:var(--text)">EEE Society</strong> — running flagship events for 1,000+ students.
          </p>
        </div>
      </div>

      <div class="about__stats reveal delay-2">
        <div class="stat">
          <div class="stat__num">8.32<span class="unit">/10</span></div>
          <div class="stat__lbl">CGPA<br/>BIT Mesra · EEE</div>
        </div>
        <div class="stat">
          <div class="stat__num">02<span class="unit">×</span></div>
          <div class="stat__lbl">AI/ML Internships<br/>Industrial</div>
        </div>
        <div class="stat">
          <div class="stat__num">01<span class="unit">×</span></div>
          <div class="stat__lbl">Patent-filed<br/>Project</div>
        </div>
        <div class="stat">
          <div class="stat__num">15<span class="unit">+</span></div>
          <div class="stat__lbl">Repositories<br/>Shipped</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       SKILLS — 02
       ============================================================ -->
  <section id="skills" class="wrap">
    <div class="sec-head reveal">
      <span class="sec-head__num">02 — Stack</span>
      <h2 class="sec-head__title">Skills &amp; <em>tools.</em></h2>
      <span class="sec-head__rule"></span>
    </div>

    <div class="skill-grid">
      <div class="skill-card reveal">
        <div class="skill-card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M12 2v6m0 8v6M4.93 4.93l4.24 4.24m5.66 5.66 4.24 4.24M2 12h6m8 0h6M4.93 19.07l4.24-4.24m5.66-5.66 4.24-4.24"/></svg>
        </div>
        <h3 class="skill-card__title">Machine&nbsp;Learning</h3>
        <div class="skill-card__sub">Models · Pipelines · Deployment</div>
        <ul class="skill-card__list">
          <li>scikit-learn</li><li>TensorFlow</li><li>Keras</li>
          <li>PyTorch</li><li>XGBoost</li><li>Feature Eng.</li>
        </ul>
      </div>

      <div class="skill-card reveal delay-1">
        <div class="skill-card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="12" cy="5" r="2.5"/><circle cx="5" cy="12" r="2.5"/><circle cx="19" cy="12" r="2.5"/><circle cx="12" cy="19" r="2.5"/><path d="M12 7.5v9M7.5 12h9M7 7l3 3M14 7l-3 3M7 17l3-3M14 17l-3-3"/></svg>
        </div>
        <h3 class="skill-card__title">Deep&nbsp;Learning &amp; AI</h3>
        <div class="skill-card__sub">Neural Nets · NLP · RL</div>
        <ul class="skill-card__list">
          <li>ANN / CNN / RNN</li><li>Transformers</li>
          <li>Reinforcement Learning</li><li>Gymnasium</li>
          <li>NLP</li><li>Computer Vision</li>
        </ul>
      </div>

      <div class="skill-card reveal delay-2">
        <div class="skill-card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 12c4-8 14-8 18 0M3 12c4 8 14 8 18 0"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <h3 class="skill-card__title">Generative&nbsp;AI</h3>
        <div class="skill-card__sub">LLMs · RAG · Agents</div>
        <ul class="skill-card__list">
          <li>OpenAI / GPT-4o</li><li>GROQ</li>
          <li>LangChain</li><li>LangGraph</li>
          <li>FAISS</li><li>RAG Pipelines</li>
        </ul>
      </div>

      <div class="skill-card reveal delay-3">
        <div class="skill-card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="3" y="4" width="18" height="16" rx="2"/><path d="M7 10h10M7 14h7M7 18h4"/></svg>
        </div>
        <h3 class="skill-card__title">Data &amp; Backend</h3>
        <div class="skill-card__sub">Storage · APIs · Pipelines</div>
        <ul class="skill-card__list">
          <li>Python</li><li>SQL</li><li>MySQL</li>
          <li>FastAPI</li><li>Streamlit</li><li>Pandas / NumPy</li>
        </ul>
      </div>

      <div class="skill-card reveal">
        <div class="skill-card__icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M4 4h16v16H4z"/><path d="M4 9h16M9 4v16"/></svg>
        </div>
        <h3 class="skill-card__title">Power &amp; Hardware</h3>
        <div class="skill-card__sub">EE Foundations</div>
        <ul class="skill-card__list">
          <li>PCB Design</li><li>Eagle</li>
          <li>MATLAB / Simulink</li><li>Arduino</li>
          <li>Atmega328P</li><li>Power Systems</li>
        </ul>
      </div>

