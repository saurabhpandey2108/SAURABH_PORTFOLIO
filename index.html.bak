              <!-- moving signal -->
              <line x1="0" y1="320" x2="460" y2="320" stroke="url(#grad)" stroke-width="2">
                <animate attributeName="x1" values="-460;460" dur="3s" repeatCount="indefinite"/>
                <animate attributeName="x2" values="0;920" dur="3s" repeatCount="indefinite"/>
              </line>
              <text x="20" y="310" fill="#5a5a66" style="font-size:10px;letter-spacing:.15em">→ TIME-SERIES CURRENT INPUT</text>
